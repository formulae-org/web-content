	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Code:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="What is wrong with the following Java code?"/>
			</expression>
			<expression tag="Visualization.CodeBlock" Value="public class HelloWorld {&#10;    public static main(String[] args) {&#10;        System.out.println(&quot;Hello, World!&quot;);&#10;    }&#10;}"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The provided Java code has a significant error in the method signature of the main method."/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Missing Return Type:"/>
					</expression>
					<expression tag="String.Text" Value=" In Java, every method must declare a return type. The main method must return void."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Incorrect Signature:"/>
					</expression>
					<expression tag="String.Text" Value="Because the return type is missing, the compiler will not recognize this as the entry point of the program."/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The corrected line should be:"/>
			</expression>
			<expression tag="Visualization.CodeBlock" Value="public static void main(String[] args) {"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Mathematical formulae:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="What is the general solution of the quadratic equation?"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="A quadratic equation is a polynomial equation of the second degree. The general form of a quadratic equation is:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Relation.Equals">
					<expression tag="Math.Arithmetic.Addition">
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Symbolic.Symbol" Name="a"/>
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Symbolic.Symbol" Name="x"/>
								<expression tag="Math.Number" Value="2"/>
							</expression>
						</expression>
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Symbolic.Symbol" Name="b"/>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Symbolic.Symbol" Name="c"/>
					</expression>
					<expression tag="Math.Number" Value="0"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="where "/>
				<expression tag="Symbolic.Symbol" Name="x"/>
				<expression tag="String.Text" Value=" represents an unknown, and "/>
				<expression tag="Symbolic.Symbol" Name="a"/>
				<expression tag="String.Text" Value=", "/>
				<expression tag="Symbolic.Symbol" Name="b"/>
				<expression tag="String.Text" Value=", and "/>
				<expression tag="Symbolic.Symbol" Name="c"/>
				<expression tag="String.Text" Value=" are coefficients with "/>
				<expression tag="Relation.Different">
					<expression tag="Symbolic.Symbol" Name="a"/>
					<expression tag="Math.Number" Value="0"/>
				</expression>
				<expression tag="String.Text" Value=". The general solution for "/>
				<expression tag="Symbolic.Symbol" Name="x"/>
				<expression tag="String.Text" Value=" is given by the quadratic formula:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Relation.Equals">
					<expression tag="Symbolic.Symbol" Name="x"/>
					<expression tag="Math.Arithmetic.Division">
						<expression tag="Visualization.PlusMinus">
							<expression tag="Math.Arithmetic.Negative">
								<expression tag="Symbolic.Symbol" Name="b"/>
							</expression>
							<expression tag="Math.Arithmetic.SquareRoot">
								<expression tag="Math.Arithmetic.Addition">
									<expression tag="Math.Arithmetic.Exponentiation">
										<expression tag="Symbolic.Symbol" Name="b"/>
										<expression tag="Math.Number" Value="2"/>
									</expression>
									<expression tag="Math.Arithmetic.Negative">
										<expression tag="Math.Arithmetic.Multiplication">
											<expression tag="Math.Number" Value="4"/>
											<expression tag="Symbolic.Symbol" Name="a"/>
											<expression tag="Symbolic.Symbol" Name="c"/>
										</expression>
									</expression>
								</expression>
							</expression>
						</expression>
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Math.Number" Value="2"/>
							<expression tag="Symbolic.Symbol" Name="a"/>
						</expression>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="This formula provides the values of "/>
				<expression tag="Symbolic.Symbol" Name="x"/>
				<expression tag="String.Text" Value=" that satisfy the quadratic equation, which can be real or complex numbers depending on the discriminant (the term under the square root)."/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="What is the name of the following identity"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Relation.Equals">
					<expression tag="Math.Arithmetic.Summation">
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Symbolic.Symbol" Name="a"/>
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Symbolic.Symbol" Name="r"/>
								<expression tag="Symbolic.Symbol" Name="k"/>
							</expression>
						</expression>
						<expression tag="Symbolic.Symbol" Name="k"/>
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Symbolic.Symbol" Name="n"/>
					</expression>
					<expression tag="Math.Arithmetic.Division">
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Symbolic.Symbol" Name="a"/>
							<expression tag="Math.Arithmetic.Addition">
								<expression tag="Math.Number" Value="1"/>
								<expression tag="Math.Arithmetic.Negative">
									<expression tag="Math.Arithmetic.Exponentiation">
										<expression tag="Symbolic.Symbol" Name="r"/>
										<expression tag="Math.Arithmetic.Addition">
											<expression tag="Symbolic.Symbol" Name="n"/>
											<expression tag="Math.Number" Value="1"/>
										</expression>
									</expression>
								</expression>
							</expression>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Number" Value="1"/>
							<expression tag="Math.Arithmetic.Negative">
								<expression tag="Symbolic.Symbol" Name="r"/>
							</expression>
						</expression>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Where"/>
				<expression tag="Relation.Different">
					<expression tag="Symbolic.Symbol" Name="r"/>
					<expression tag="Math.Number" Value="1"/>
				</expression>
				<expression tag="String.Text" Value="?"/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="This is the formula for the"/>
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="sum of a finite geometric series"/>
			</expression>
			<expression tag="String.Text" Value=" (also known as a geometric progression sum)."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="How is defined the"/>
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Kronecker product"/>
			</expression>
			<expression tag="String.Text" Value="? Provide an example"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The "/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Kronecker product"/>
				</expression>
				<expression tag="String.Text" Value=" (also known as the matrix product or tensor product) of two matrices is an operation that results in a block matrix. Specifically, if matrix A is of size m × n and matrix B is of size p × q, their Kronecker product A ⊗ B is a matrix of size (m × p) × (n × q), where each element of A is multiplied by the entire matrix B."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="An example with a 2×2 matrix A and a 2×2 matrix B:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Math.Matrix.KroneckerProduct">
					<expression tag="List.List">
						<expression tag="List.List">
							<expression tag="Math.Number" Value="1"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
						<expression tag="List.List">
							<expression tag="Math.Number" Value="3"/>
							<expression tag="Math.Number" Value="4"/>
						</expression>
					</expression>
					<expression tag="List.List">
						<expression tag="List.List">
							<expression tag="Math.Number" Value="0"/>
							<expression tag="Math.Number" Value="1"/>
						</expression>
						<expression tag="List.List">
							<expression tag="Math.Number" Value="1"/>
							<expression tag="Math.Number" Value="0"/>
						</expression>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The resulting matrix is:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="List.List">
					<expression tag="List.List">
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="1"/>
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="2"/>
					</expression>
					<expression tag="List.List">
						<expression tag="Math.Number" Value="1"/>
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="2"/>
						<expression tag="Math.Number" Value="0"/>
					</expression>
					<expression tag="List.List">
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="3"/>
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="4"/>
					</expression>
					<expression tag="List.List">
						<expression tag="Math.Number" Value="3"/>
						<expression tag="Math.Number" Value="0"/>
						<expression tag="Math.Number" Value="4"/>
						<expression tag="Math.Number" Value="0"/>
					</expression>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="List five formulas of differentiation"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Here are five basic formulas of differentiation:"/>
			</expression>
			<expression tag="Typesetting.NumberedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Power Rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Differential.TotalDerivative">
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Symbolic.Symbol" Name="x"/>
								<expression tag="Symbolic.Symbol" Name="n"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Multiplication">
							<expression tag="Symbolic.Symbol" Name="n"/>
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Symbolic.Symbol" Name="x"/>
								<expression tag="Math.Arithmetic.Addition">
									<expression tag="Symbolic.Symbol" Name="n"/>
									<expression tag="Math.Arithmetic.Negative">
										<expression tag="Math.Number" Value="1"/>
									</expression>
								</expression>
							</expression>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Constant Rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Differential.TotalDerivative">
							<expression tag="Symbolic.Symbol" Name="c"/>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Number" Value="0"/>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Sine Rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Differential.TotalDerivative">
							<expression tag="Math.Trigonometric.Sine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Trigonometric.Cosine">
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Cosine Rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Differential.TotalDerivative">
							<expression tag="Math.Trigonometric.Cosine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Negative">
							<expression tag="Math.Trigonometric.Sine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Exponential Rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Differential.TotalDerivative">
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Math.Constant.Euler"/>
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Exponentiation">
							<expression tag="Math.Constant.Euler"/>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
					</expression>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="List five basic formulas of integration"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Here are five basic formulas of integration:"/>
			</expression>
			<expression tag="Typesetting.NumberedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Power rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Integral.IndefiniteIntegral">
							<expression tag="Math.Arithmetic.Exponentiation">
								<expression tag="Symbolic.Symbol" Name="x"/>
								<expression tag="Symbolic.Symbol" Name="n"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Arithmetic.Division">
								<expression tag="Math.Arithmetic.Exponentiation">
									<expression tag="Symbolic.Symbol" Name="x"/>
									<expression tag="Math.Arithmetic.Addition">
										<expression tag="Symbolic.Symbol" Name="n"/>
										<expression tag="Math.Number" Value="1"/>
									</expression>
								</expression>
								<expression tag="Math.Arithmetic.Addition">
									<expression tag="Symbolic.Symbol" Name="n"/>
									<expression tag="Math.Number" Value="1"/>
								</expression>
							</expression>
							<expression tag="Symbolic.Symbol" Name="C"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Exponential rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Integral.IndefiniteIntegral">
							<expression tag="Math.Constant.Euler"/>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Constant.Euler"/>
							<expression tag="Symbolic.Symbol" Name="C"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Reciprocal rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Integral.IndefiniteIntegral">
							<expression tag="Math.Arithmetic.Division">
								<expression tag="Math.Number" Value="1"/>
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Transcendental.NaturalLogarithm">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="C"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Sine rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Integral.IndefiniteIntegral">
							<expression tag="Math.Trigonometric.Sine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Arithmetic.Negative">
								<expression tag="Math.Trigonometric.Cosine">
									<expression tag="Symbolic.Symbol" Name="x"/>
								</expression>
							</expression>
							<expression tag="Symbolic.Symbol" Name="C"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Cosine rule:"/>
					</expression>
					<expression tag="String.Text" Value=" "/>
					<expression tag="Relation.Equals">
						<expression tag="Calculus.Integral.IndefiniteIntegral">
							<expression tag="Math.Trigonometric.Cosine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="x"/>
						</expression>
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Trigonometric.Sine">
								<expression tag="Symbolic.Symbol" Name="x"/>
							</expression>
							<expression tag="Symbolic.Symbol" Name="C"/>
						</expression>
					</expression>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Multimodality. Image identification:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Describe the following image:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="This image depicts the "/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Hylian Crest,"/>
				</expression>
				<expression tag="String.Text" Value=" a prominent symbol from the "/>
				<expression tag="Typesetting.ItalicChunk">
					<expression tag="String.Text" Value="The Legend of Zelda"/>
				</expression>
				<expression tag="String.Text" Value=" series."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The emblem features a gold-colored stylized bird, resembling a phoenix or eagle, with its wings outstretched. Nestled above the bird is the "/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Triforce,"/>
				</expression>
				<expression tag="String.Text" Value=" consisting of three interlocking golden triangles."/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Multimodality. Audio transcription:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Transcribe the following speech:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Audio.WaveformAudio" Value="" Format="audio/mpeg"/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="I propose to consider the question “Can machines think?” This should begin with definitions of the meaning of the terms “machine” and “think”. The definitions might be framed so as to reflect, so far as possible, the normal use of the words, but this attitude is dangerous. If the meaning of the words “machine” and “think” are to be found by examining how they are commonly used, it is difficult to escape the conclusion that the meaning, and the answer to the question “Can machines think”, is to be sought in a statistical survey such as a Gallup poll. But this is absurd. Instead of attempting such a definition, I shall replace the question by another, which is closely related to it and is expressed in relatively unambiguous words."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Author: Laurence R. Ugalde"/>
			</expression>
