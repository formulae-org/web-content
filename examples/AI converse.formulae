<expression tag="Formulae.Script" Modules="org.formulae.typesetting,org.formulae.text.string,org.formulae.list,org.formulae.visualization,org.formulae.chemistry,org.formulae.math.arithmetic,org.formulae.diagramming,org.formulae.internet,org.formulae.relation,org.formulae.symbolic,org.formulae.matrix,org.formulae.calculus,org.formulae.graphics.raster,org.formulae.audio,org.formulae.time">
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Introduction"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Fōrmulæ can converse with AI models. When a paragraph expression is evaluated, it is sent as a prompt to the active AI connection; the model's response appears as a new output row in the form of a Fōrmulæ expression, in gray background."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The following examples demonstrate the range of response types: prose, formatted lists, tables, chemical formulae, diagrams, mathematical notation, source code, colored output, and multimodal prompts that include images and audio."/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Prose text:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="Show me the first 3 paragraphs of the book"/>
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Don Quixote of La Mancha"/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Somewhere in La Mancha, in a place whose name I do not care to remember, a gentleman lived not long ago, one of those who have a lance in the lance-rack, an ancient shield, a skinny nag, and a greyhound for racing."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="A stew with more beef than mutton, chopped meat for most nights, lentils on Fridays, bacon and eggs on Saturdays, and a pigeon as an extra on Sundays, consumed three-fourths of his income. The rest of it went for a doublet of fine cloth, velvet breeches and slippers for holidays, and a homespun suit of the best cloth for weekdays."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="He had in his house a housekeeper past forty, a niece under twenty, and a farmhand and fieldworker who could saddle a horse and wield a pruning hook, and set a hoe. The master himself was nearly fifty, of a robust constitution but with little flesh and a dry face, an early riser and a great friend of hunting."/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Formatted text:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="In what order should the"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Star Wars"/>
				</expression>
				<expression tag="String.Text" Value="franchise movies and series be watched so that the events are observed chronologically, and not by release date?"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="If the entry is a series, include the number of episodes."/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Here is a chronological watch order for the "/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Star Wars"/>
				</expression>
				<expression tag="String.Text" Value=" franchise, focusing on the main canon movies and series. Note that some series may have overlapping timelines with other entries."/>
			</expression>
			<expression tag="Typesetting.NumberedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode I – The Phantom Menace"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode II – Attack of the Clones"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: The Clone Wars"/>
					</expression>
					<expression tag="String.Text" Value=" (Animated Series, 7 seasons, 133 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode III – Revenge of the Sith"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: The Bad Batch"/>
					</expression>
					<expression tag="String.Text" Value=" (Animated Series, 3 seasons, 36 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Solo: A Star Wars Story"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Obi-Wan Kenobi"/>
					</expression>
					<expression tag="String.Text" Value=" (Live-action Series, 1 season, 6 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Andor"/>
					</expression>
					<expression tag="String.Text" Value=" (Live-action Series, 1 season, 12 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars Rebels"/>
					</expression>
					<expression tag="String.Text" Value=" (Animated Series, 4 seasons, 75 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Rogue One: A Star Wars Story"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode IV – A New Hope"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode V – The Empire Strikes Back"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode VI – Return of the Jedi"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="The Mandalorian"/>
					</expression>
					<expression tag="String.Text" Value=" (Live-action Series, 3 seasons, 24 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="The Book of Boba Fett"/>
					</expression>
					<expression tag="String.Text" Value=" (Live-action Series, 1 season, 7 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Ahsoka"/>
					</expression>
					<expression tag="String.Text" Value=" (Live-action Series, 1 season, 8 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars Resistance"/>
					</expression>
					<expression tag="String.Text" Value=" (Animated Series, 2 seasons, 40 episodes)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode VII – The Force Awakens"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode VIII – The Last Jedi"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Star Wars: Episode IX – The Rise of Skywalker"/>
					</expression>
					<expression tag="String.Text" Value=" (Movie)"/>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Tables:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="Create a table for the 10 most spoken human languages. On each row, show the name of the language and the translation of the term"/>
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Artificial Intelligence"/>
			</expression>
			<expression tag="String.Text" Value="in that language."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="List.Table">
			<expression tag="List.List">
				<expression tag="List.List">
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Language"/>
					</expression>
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Translation of 'Artificial Intelligence'"/>
					</expression>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="English"/>
					<expression tag="String.Text" Value="Artificial Intelligence"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Mandarin Chinese"/>
					<expression tag="String.Text" Value="人工智能 (Réngōng Zhìnéng)"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Hindi"/>
					<expression tag="String.Text" Value="कृत्रिम बुद्धिमत्ता (Kritrim Buddhimatta)"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Spanish"/>
					<expression tag="String.Text" Value="Inteligencia Artificial"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="French"/>
					<expression tag="String.Text" Value="Intelligence Artificielle"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Modern Standard Arabic"/>
					<expression tag="String.Text" Value="الذكاء الاصطناعي (Al-Dhaka' al-Istina'i)"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Bengali"/>
					<expression tag="String.Text" Value="কৃত্রিম বুদ্ধিমত্তা (Kritrim Buddhimatta)"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Portuguese"/>
					<expression tag="String.Text" Value="Inteligência Artificial"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Russian"/>
					<expression tag="String.Text" Value="Искусственный интеллект (Iskusstvennyy intellekt)"/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Urdu"/>
					<expression tag="String.Text" Value="مصنوعی ذہانت (Masnooyi Zehanat)"/>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Chemical formulae:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="Create a table with the 10 most dangerous chemical compounds. Each row should contain the name, the chemical formula, and the risk."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="List.Table">
			<expression tag="List.List">
				<expression tag="List.List">
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Name"/>
					</expression>
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Chemical Formula"/>
					</expression>
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Risk"/>
					</expression>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Hydrogen Cyanide"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.Element.Hydrogen"/>
						<expression tag="Chemistry.Element.Carbon"/>
						<expression tag="Chemistry.Element.Nitrogen"/>
					</expression>
					<expression tag="String.Text" Value="Extremely toxic, interferes with cellular respiration."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Sarin"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Carbon"/>
							<expression tag="Math.Number" Value="4"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Hydrogen"/>
							<expression tag="Math.Number" Value="10"/>
						</expression>
						<expression tag="Chemistry.Element.Fluorine"/>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Oxygen"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
						<expression tag="Chemistry.Element.Phosphorus"/>
					</expression>
					<expression tag="String.Text" Value="Potent nerve agent causing paralysis and death."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Potassium Cyanide"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.Element.Potassium"/>
						<expression tag="Chemistry.Element.Carbon"/>
						<expression tag="Chemistry.Element.Nitrogen"/>
					</expression>
					<expression tag="String.Text" Value="Rapidly fatal, inhibits cellular respiration."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Arsenic Trioxide"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Arsenic"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Oxygen"/>
							<expression tag="Math.Number" Value="3"/>
						</expression>
					</expression>
					<expression tag="String.Text" Value="Highly poisonous, carcinogen."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Mercury"/>
					<expression tag="Chemistry.Element.Mercury"/>
					<expression tag="String.Text" Value="Neurotoxin, causes severe neurological and developmental damage."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Chlorine Gas"/>
					<expression tag="Chemistry.HomonuclearCompound">
						<expression tag="Chemistry.Element.Chlorine"/>
						<expression tag="Math.Number" Value="2"/>
					</expression>
					<expression tag="String.Text" Value="Highly toxic respiratory irritant, causes lung damage."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Phosgene"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.Element.Carbon"/>
						<expression tag="Chemistry.Element.Oxygen"/>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Chlorine"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
					</expression>
					<expression tag="String.Text" Value="Highly toxic gas, causes delayed severe lung edema."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Thallium Sulfate"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Thallium"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
						<expression tag="Chemistry.Element.Sulfur"/>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Oxygen"/>
							<expression tag="Math.Number" Value="4"/>
						</expression>
					</expression>
					<expression tag="String.Text" Value="Extremely toxic, causes neurological damage and hair loss."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Strychnine"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Carbon"/>
							<expression tag="Math.Number" Value="21"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Hydrogen"/>
							<expression tag="Math.Number" Value="22"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Nitrogen"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Oxygen"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
					</expression>
					<expression tag="String.Text" Value="Potent neurotoxin, causes painful convulsions and respiratory arrest."/>
				</expression>
				<expression tag="List.List">
					<expression tag="String.Text" Value="Dioxin (TCDD)"/>
					<expression tag="Chemistry.HeteronuclearCompound">
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Carbon"/>
							<expression tag="Math.Number" Value="12"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Hydrogen"/>
							<expression tag="Math.Number" Value="4"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Chlorine"/>
							<expression tag="Math.Number" Value="4"/>
						</expression>
						<expression tag="Chemistry.HomonuclearCompound">
							<expression tag="Chemistry.Element.Oxygen"/>
							<expression tag="Math.Number" Value="2"/>
						</expression>
					</expression>
					<expression tag="String.Text" Value="Extremely toxic, highly carcinogenic, persistent environmental pollutant."/>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Example. Formatting output:"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="Create an array containing, for each of the main colors, the name of the color colored with its own color"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="List.List">
			<expression tag="Visualization.Color" Red="1" Green="0" Blue="0" Alpha="1">
				<expression tag="String.Text" Value="Red"/>
			</expression>
			<expression tag="Visualization.Color" Red="0" Green="1" Blue="0" Alpha="1">
				<expression tag="String.Text" Value="Green"/>
			</expression>
			<expression tag="Visualization.Color" Red="0" Green="0" Blue="1" Alpha="1">
				<expression tag="String.Text" Value="Blue"/>
			</expression>
			<expression tag="Visualization.Color" Red="1" Green="1" Blue="0" Alpha="1">
				<expression tag="String.Text" Value="Yellow"/>
			</expression>
			<expression tag="Visualization.Color" Red="0" Green="1" Blue="1" Alpha="1">
				<expression tag="String.Text" Value="Cyan"/>
			</expression>
			<expression tag="Visualization.Color" Red="1" Green="0" Blue="1" Alpha="1">
				<expression tag="String.Text" Value="Magenta"/>
			</expression>
			<expression tag="Visualization.Color" Red="0" Green="0" Blue="0" Alpha="1">
				<expression tag="String.Text" Value="Black"/>
			</expression>
			<expression tag="Visualization.Color" Red="1" Green="1" Blue="1" Alpha="1">
				<expression tag="String.Text" Value="White"/>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Create a table, where each row corresponds to values from 12 to 72, skipping every 12."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Each row must contain the following columns:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="String.Text" Value="The value"/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="String.Text" Value="The name of the value (e.g. the name of 1 is &quot;one&quot;), displayed in a font size equal to the value"/>
				</expression>
			</expression>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="List.Table">
			<expression tag="List.List">
				<expression tag="List.List">
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Value"/>
					</expression>
					<expression tag="Visualization.Bold" Value="True" Set="True">
						<expression tag="String.Text" Value="Name"/>
					</expression>
				</expression>
				<expression tag="List.List">
					<expression tag="Math.Number" Value="12"/>
					<expression tag="Visualization.FontSize" Size="12">
						<expression tag="String.Text" Value="twelve"/>
					</expression>
				</expression>
				<expression tag="List.List">
					<expression tag="Math.Number" Value="24"/>
					<expression tag="Visualization.FontSize" Size="24">
						<expression tag="String.Text" Value="twenty-four"/>
					</expression>
				</expression>
				<expression tag="List.List">
					<expression tag="Math.Number" Value="36"/>
					<expression tag="Visualization.FontSize" Size="36">
						<expression tag="String.Text" Value="thirty-six"/>
					</expression>
