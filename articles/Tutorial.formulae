					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Arrow keys"/>
					</expression>
					<expression tag="String.Text" Value=" — move the selection to the nearest leaf expression in that direction, crossing expression boundaries as needed. For example, pressing the right arrow from the last child of one expression moves to the first child of the next expression."/>
				</expression>
