			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The status bar shows information about the"/>
				<expression tag="String.Text" Value="selected"/>
				<expression tag="String.Text" Value="expression (in black). It displays the type of the expression, the index of its parent and the type of the parent expression."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The same information is shown for the"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="highlighted"/>
				</expression>
				<expression tag="String.Text" Value="expression (in blue, if there is one). The root expression has no parent, so parent information is not shown."/>
			</expression>
			<expression tag="Typesetting.Centering">
