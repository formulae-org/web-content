<expression tag="Formulae.Script" Modules="org.formulae.typesetting,org.formulae.text.string,org.formulae.graphics.raster,org.formulae.list,org.formulae.visualization,org.formulae.internet,org.formulae.math.arithmetic,org.formulae.symbolic">
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.MultiParagraph">
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Getting started with Fōrmulæ"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="What is Fōrmulæ?"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Fōrmulæ is a system for working with expressions — structured objects that can be displayed, evaluated, and used as prompts to AI models. Every item in the workspace is an expression. Expressions can contain other expressions, building up arbitrarily complex structures."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="You can do three things with an expression:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Compose"/>
					</expression>
					<expression tag="String.Text" Value=" — leave it in place as part of a document. Fōrmulæ renders mathematics, formatted text, tables, diagrams, and images in a two-dimensional, pretty-print layout. No output row is created."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Compute"/>
					</expression>
					<expression tag="String.Text" Value=" — press Enter to pass the expression to the computing engine. The result appears in an output row below."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Converse"/>
					</expression>
					<expression tag="String.Text" Value=" — write a paragraph expression and press Enter to send it as a prompt to the active AI model. The AI's response — itself a Fōrmulæ expression — appears in the output row."/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="The interface"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The interface has four areas:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Toolbar"/>
					</expression>
					<expression tag="String.Text" Value=" — a row of buttons at the top of the screen."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Editing panel"/>
					</expression>
					<expression tag="String.Text" Value=" — a collapsible tree of editing operations at the left of the screen. It lists all ways to create or modify expressions, organized hierarchically. Many entries include an icon."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Workspace"/>
					</expression>
					<expression tag="String.Text" Value=" — the central area where the script is displayed and edited."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Status bar"/>
					</expression>
					<expression tag="String.Text" Value=" — two lines at the bottom showing information about the selected and highlighted expressions."/>
				</expression>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.Centering">
					<expression tag="String.Text" Value="Full browser window in edit mode with the four interface areas labeled."/>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="View mode and edit mode"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Fōrmulæ starts in"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" view mode"/>
				</expression>
				<expression tag="String.Text" Value=". In view mode, expressions are not editable, and the toolbar shows only three buttons: New, Open file, and Edit/run. Press"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Edit/run "/>
				</expression>
				<expression tag="String.Text" Value="to enter"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" edit mode"/>
				</expression>
				<expression tag="String.Text" Value=", where expressions are fully editable and the full toolbar, editing panel, and status bar are visible. Press"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Exit edit/run "/>
				</expression>
				<expression tag="String.Text" Value="to return to view mode."/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="List.Table">
					<expression tag="List.List">
						<expression tag="List.List">
							<expression tag="Visualization.Bold" Value="True" Set="True">
								<expression tag="String.Text" Value="Mode"/>
							</expression>
							<expression tag="Visualization.Bold" Value="True" Set="True">
								<expression tag="String.Text" Value="Toolbar"/>
							</expression>
						</expression>
						<expression tag="List.List">
							<expression tag="String.Text" Value="View mode"/>
							<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
						</expression>
						<expression tag="List.List">
							<expression tag="String.Text" Value="Edit mode"/>
							<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
						</expression>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Rows"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The workspace is a sequence of rows. There are three kinds:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Input rows"/>
					</expression>
					<expression tag="String.Text" Value=" (white background) — where you build expressions. They are editable."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Output rows"/>
					</expression>
					<expression tag="String.Text" Value=" (gray background) — the result of computing or conversing. Always appear directly below their input row. Not editable."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Definition rows"/>
					</expression>
					<expression tag="String.Text" Value=" (wheat-colored background) — like input rows, but results are never shown. Use them for global definitions (assignments like x ← 5) that need to be re-executed every time the script is loaded. Press Execute definition rows in the toolbar to replay them all at once."/>
				</expression>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Use the toolbar to manage rows:"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Insert row below"/>
				</expression>
				<expression tag="String.Text" Value=" and"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Insert row above "/>
				</expression>
				<expression tag="String.Text" Value="add rows;"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Delete row "/>
				</expression>
				<expression tag="String.Text" Value="removes the current row (and its output row if present);"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value=" Change type "/>
				</expression>
				<expression tag="String.Text" Value="toggles between input and definition rows."/>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Your first expression"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="When you press the"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="New"/>
				</expression>
				<expression tag="String.Text" Value="button ("/>
				<expression tag="Graphics.RasterGraphics" Value="iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAAf0lEQVR4AcSSQQ6AIAwExTv/fygPwB1IGgpGISZoum7FMkrhPD5eDhBjzOLl3hmTbsMBUkoUBXlQYq6cAI47OYB7Mz4AHSArAJYG1kFmAXy9LEn9AWKaBdgE9cdykmUAk1rtB/zfgy1/wEF5UrsJR78L5cCo4s1VUqMH1NGF+wUAAP//NQfbcQAAAAZJREFUAwA15Sghz4rPQgAAAABJRU5ErkJggg==" Format="image/png"/>
				<expression tag="String.Text" Value=") in the toolbar, the workspace shows a single input row containing a"/>
				<expression tag="Internet.Hyperlink" Value="/?script=reference/Null" Description="null"/>
				<expression tag="String.Text" Value="expression ("/>
				<expression tag="Null"/>
				<expression tag="String.Text" Value="). This small rectangle is a placeholder waiting to be filled. All editing operations act on the selected expression, shown in inverse video (white content on black background). At the start, the"/>
				<expression tag="Internet.Hyperlink" Value="/?script=reference/Null" Description="null"/>
				<expression tag="String.Text" Value="expression is selected."/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="To create the expression 2 + 3, follow these steps:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.MultiParagraph">
					<expression tag="Typesetting.Paragraph">
						<expression tag="String.Text" Value="Initially, there is only the"/>
						<expression tag="Internet.Hyperlink" Value="/?script=reference/Null" Description="null"/>
						<expression tag="String.Text" Value="expression, and it is selected:"/>
					</expression>
					<expression tag="Typesetting.Centering">
						<expression tag="Visualization.Selected">
							<expression tag="Null"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.MultiParagraph">
					<expression tag="Typesetting.Paragraph">
						<expression tag="String.Text" Value="Open"/>
						<expression tag="Typesetting.BoldChunk">
							<expression tag="String.Text" Value=" Math → Number"/>
						</expression>
						<expression tag="String.Text" Value="in the editing panel. A dialog appears — type"/>
						<expression tag="Visualization.Code">
							<expression tag="String.Text" Value=" 2 "/>
						</expression>
						<expression tag="String.Text" Value="and press"/>
						<expression tag="Visualization.Key">
							<expression tag="String.Text" Value="Enter"/>
						</expression>
						<expression tag="String.Text" Value=". The number 2 substitutes the"/>
						<expression tag="Internet.Hyperlink" Value="/?script=reference/Null" Description="null"/>
						<expression tag="String.Text" Value="expression and becomes the selected expression."/>
					</expression>
					<expression tag="Typesetting.Centering">
						<expression tag="Visualization.Selected">
							<expression tag="Math.Number" Value="2"/>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.MultiParagraph">
					<expression tag="Typesetting.Paragraph">
						<expression tag="String.Text" Value="Open"/>
						<expression tag="Typesetting.BoldChunk">
							<expression tag="String.Text" Value=" Math → Arithmetic → Addition → Append addend "/>
						</expression>
						<expression tag="String.Text" Value="in the editing panel. A"/>
						<expression tag="Internet.Hyperlink" Value="/?script=reference/Null" Description="null"/>
						<expression tag="String.Text" Value="addend is created after the number 2, and it becomes the selected expression."/>
					</expression>
					<expression tag="Typesetting.Centering">
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Number" Value="2"/>
							<expression tag="Visualization.Selected">
								<expression tag="Null"/>
							</expression>
						</expression>
					</expression>
				</expression>
				<expression tag="Typesetting.MultiParagraph">
					<expression tag="Typesetting.Paragraph">
						<expression tag="String.Text" Value="Open"/>
						<expression tag="Typesetting.BoldChunk">
							<expression tag="String.Text" Value=" Math → Number "/>
						</expression>
						<expression tag="String.Text" Value="again, type"/>
						<expression tag="Visualization.Code">
							<expression tag="String.Text" Value=" 3 "/>
						</expression>
						<expression tag="String.Text" Value=", and press"/>
						<expression tag="Visualization.Key">
							<expression tag="String.Text" Value="Enter"/>
						</expression>
						<expression tag="String.Text" Value="."/>
					</expression>
					<expression tag="Typesetting.Centering">
						<expression tag="Math.Arithmetic.Addition">
							<expression tag="Math.Number" Value="2"/>
							<expression tag="Visualization.Selected">
								<expression tag="Math.Number" Value="3"/>
							</expression>
						</expression>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Computing"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="To compute an expression, press"/>
				<expression tag="Visualization.Key">
					<expression tag="String.Text" Value="Enter"/>
				</expression>
				<expression tag="String.Text" Value=". The computing engine evaluates the expression and places the result in an output row immediately below. For 2 + 3, the result is 5."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Input rows have a white background. Output rows have a gray background and are not editable."/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Graphics.RasterGraphics" Value="" Format="image/png"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="After the result appears, a new empty input row is added below it and its first slot is selected — ready for your next expression."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="To evaluate an expression without keeping the result, press"/>
				<expression tag="Visualization.Key">
					<expression tag="String.Text" Value="Alt"/>
				</expression>
				<expression tag="Visualization.Key">
					<expression tag="String.Text" Value="Enter"/>
				</expression>
				<expression tag="String.Text" Value="— the expression is evaluated but the output row is not shown (or is deleted if it already exists)."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
