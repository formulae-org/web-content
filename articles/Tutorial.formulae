			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Composing"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Not every expression needs to be evaluated. If you leave an expression in an input row without pressing"/>
				<expression tag="Visualization.Key">
					<expression tag="String.Text" Value="Enter"/>
				</expression>
				<expression tag="String.Text" Value=", it stays as part of the visual presentation of the script — this is called"/>
				<expression tag="Typesetting.ItalicChunk">
					<expression tag="String.Text" Value=" composing"/>
				</expression>
				<expression tag="String.Text" Value=". No output row is created. Fōrmulæ renders mathematical expressions, formatted text, tables, images, and diagrams in a two-dimensional, pretty-print layout."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="A Fōrmulæ file can simultaneously be a runnable program and a human-readable document. In fact, this tutorial is a composed Fōrmulæ file — you are reading it in view mode right now."/>
			</expression>
			<expression tag="Typesetting.Rule"/>
			<expression tag="Typesetting.Paragraph">
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Conversing"/>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Three expressions are involved in conversing:"/>
			</expression>
			<expression tag="Typesetting.BulletedList">
				<expression tag="Typesetting.Paragraph">
					<expression tag="String.Text" Value="The"/>
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Text"/>
					</expression>
					<expression tag="String.Text" Value="expression. It is an expression intended to hold arbitrary text such as a sentence or phrase."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="String.Text" Value="The"/>
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Paragraph"/>
					</expression>
					<expression tag="String.Text" Value="expression represents a typographical paragraph. It usually contains one or several"/>
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Text"/>
					</expression>
					<expression tag="String.Text" Value="subexpressions. It arranges their words into lines with proper spacing and justification. It can also hold other kinds of expressions inline — for example, a mathematical formula embedded within a sentence."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="String.Text" Value="The"/>
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Multiparagraph"/>
					</expression>
					<expression tag="String.Text" Value="is just a sequence of"/>
					<expression tag="Typesetting.BoldChunk">
						<expression tag="String.Text" Value="Paragraphs."/>
					</expression>
				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="When the root expression in an input row is a"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Paragraph"/>
				</expression>
				<expression tag="String.Text" Value="or"/>
				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Multiparagraph"/>
				</expression>
				<expression tag="String.Text" Value="expression, pressing"/>
				<expression tag="Visualization.Key">
					<expression tag="String.Text" Value="Enter"/>
				</expression>
				<expression tag="String.Text" Value="sends it to the active AI model instead of the computing engine. The AI's response — itself a Fōrmulæ expression of any type — appears in the output row."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="Before you can interact with an AI model, you need to configure one or several"/>
