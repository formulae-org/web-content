			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="With Scale."/>
			</expression>
			<expression tag="String.Text" Value="If a Scale is given, it must reduce to an integer; otherwise the reduction raises an error. A positive Scale of"/>
			<expression tag="Symbolic.Symbol" Name="n"/>
			<expression tag="String.Text" Value="rounds the Argument down to"/>
			<expression tag="Symbolic.Symbol" Name="n"/>
			<expression tag="String.Text" Value="decimal places:"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Math.Arithmetic.Floor">
			<expression tag="Math.Number" Value="2.756"/>
			<expression tag="Math.Number" Value="2"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="1">
