	<expression tag="Formulae.Script.Row" type="1">
		<expression tag="Math.Number" Value="2.2360679774997896964"/>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Negative integer radicand."/>
			</expression>
			<expression tag="String.Text" Value="If the radicand is a negative integer, the result depends on whether its absolute value is a perfect square. If it is a perfect square"/>
			<expression tag="Relation.Equals">
				<expression tag="Symbolic.Symbol" Name="n"/>
				<expression tag="Math.Arithmetic.Negative">
					<expression tag="Math.Arithmetic.Exponentiation">
						<expression tag="Symbolic.Symbol" Name="k"/>
						<expression tag="Math.Number" Value="2"/>
					</expression>
				</expression>
			</expression>
			<expression tag="String.Text" Value=", the result is the purely imaginary complex number"/>
			<expression tag="Math.Arithmetic.Multiplication">
				<expression tag="Symbolic.Symbol" Name="k"/>
				<expression tag="Math.Complex.ImaginaryUnit"/>
			</expression>
			<expression tag="String.Text" Value="(e.g.,"/>
			<expression tag="Relation.Equals">
				<expression tag="Math.Arithmetic.SquareRoot">
					<expression tag="Math.Arithmetic.Negative">
						<expression tag="Math.Number" Value="9"/>
					</expression>
				</expression>
				<expression tag="Math.Arithmetic.Multiplication">
					<expression tag="Math.Number" Value="3"/>
					<expression tag="Math.Complex.ImaginaryUnit"/>
				</expression>
			</expression>
			<expression tag="String.Text" Value="). Otherwise, the result is"/>
			<expression tag="Math.Complex.ImaginaryUnit"/>
			<expression tag="String.Text" Value="times the square root of the absolute value:"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
