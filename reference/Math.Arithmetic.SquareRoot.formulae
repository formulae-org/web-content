				<expression tag="Typesetting.BoldChunk">
					<expression tag="String.Text" Value="Perfect-square integer radicand."/>
				</expression>
				<expression tag="String.Text" Value="If the radicand is a positive integer that is a perfect square n = k², the result is the exact integer k:"/>
			</expression>
		</expression>
	</expression>
