				</expression>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The Null expression is shown as a rectangle, such as follows:"/>
			</expression>
			<expression tag="Typesetting.Centering">
				<expression tag="Null"/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="This height is the same size as the size (in points) of the font currently being used for edition."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="This width is the rounded value of 0.618 of its height. Its value is intended to make the proportion between the height and the width to approximate to the"/>
				<expression tag="Internet.Hyperlink" Value="https://en.wikipedia.org/wiki/Golden_ratio" Description="golden ratio."/>
			</expression>
