			</expression>
			<expression tag="String.Text" Value="; children 2 and 3 must reduce to non-complex numbers (the lower and upper bounds). The iteration step is 1."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Math.Arithmetic.Product">
