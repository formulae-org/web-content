	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="In the 5-subexpression form: child 4 must reduce to a non-complex, non-zero number (the step). If the step is positive the iteration continues while the variable is less than or equal to the upper bound; if the step is negative, while the variable is greater than or equal to the upper bound:"/>
		</expression>
