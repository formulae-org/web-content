				<expression tag="String.Text" Value="The"/>
				<expression tag="Visualization.Code">
					<expression tag="String.Text" Value="Math.Constant.Euler"/>
				</expression>
				<expression tag="String.Text" Value="expression represents the mathematical constant"/>
				<expression tag="Math.Constant.Euler"/>
				<expression tag="String.Text" Value=", the base of the natural logarithm. It is an irrational transcendental number approximately equal to 2.71828182845904..."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="In symbolic mode (the default),"/>
				<expression tag="Math.Constant.Euler"/>
				<expression tag="String.Text" Value="is left unreduced and remains as the symbol"/>
				<expression tag="Math.Constant.Euler"/>
				<expression tag="String.Text" Value=". In numeric mode — for example, when wrapped in a"/>
				<expression tag="Visualization.Code">
					<expression tag="String.Text" Value="Math.Arithmetic.Numeric"/>
				</expression>
				<expression tag="String.Text" Value="expression — it is replaced by the decimal value of"/>
				<expression tag="Math.Constant.Euler"/>
				<expression tag="String.Text" Value="computed to the current precision."/>
			</expression>
			<expression tag="Typesetting.Paragraph">
				<expression tag="String.Text" Value="The name of this expression depends on locale. In English, it is"/>
				<expression tag="Typesetting.ItalicChunk">
					<expression tag="String.Text" Value="Euler number"/>
				</expression>
				<expression tag="String.Text" Value="."/>
			</expression>
