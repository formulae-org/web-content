	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Complex Argument."/>
			</expression>
			<expression tag="String.Text" Value="If the Argument is a complex number z = a + bi, the absolute value expression is replaced by the value of sqrt(a² + b²). In the following example, 3² + 4² = 25, whose square root is the exact integer 5:"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Math.Arithmetic.AbsoluteValue">
			<expression tag="Math.Arithmetic.Addition">
