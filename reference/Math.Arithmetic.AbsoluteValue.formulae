	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="String.Text" Value="Three cases are handled when the Argument is an internal number."/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
		<expression tag="Typesetting.Paragraph">
			<expression tag="Typesetting.BoldChunk">
				<expression tag="String.Text" Value="Non-negative real Argument."/>
			</expression>
			<expression tag="String.Text" Value="If the Argument is a non-negative real number, the absolute value expression is replaced by the Argument itself:"/>
		</expression>
	</expression>
	<expression tag="Formulae.Script.Row" type="0">
