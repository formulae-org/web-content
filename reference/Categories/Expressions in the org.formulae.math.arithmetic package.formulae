				<expression tag="Typesetting.Paragraph">
					<expression tag="Internet.Hyperlink" Value="/?script=reference/Math.Infinity" Description="Math.Infinity"/>
					<expression tag="String.Text" Value=". The expression associated with positive infinity."/>
				</expression>
				<expression tag="Typesetting.Paragraph">
					<expression tag="Internet.Hyperlink" Value="/?script=reference/Math.Number" Description="Math.Number"/>
